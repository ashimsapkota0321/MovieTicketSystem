@startuml
left to right direction
skinparam backgroundColor #0f1117
skinparam defaultFontColor #e6e6e6
skinparam defaultFontName Segoe UI
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #1f2430
  BorderColor #c0c0c0
  FontColor #f2f2f2
}
skinparam rectangle {
  BackgroundColor #101521
  BorderColor #8a8a8a
  FontColor #f2f2f2
}

actor "System Manager\n(Admin)" as Admin
actor Vendor
actor "Vendor Staff" as VStaff
actor User
actor Guest
actor Customer
actor "Payment Gateway\n(eSewa)" as PG
actor "Notification Service" as NS

Guest -|> User
Customer -|> User
VStaff -|> Vendor

rectangle "Movie Ticket Management System - MeroTicket" {

  usecase "Register Account" as UC_Register
  usecase "Login" as UC_Login
  usecase "Forgot/Reset Password" as UC_ResetPass
  usecase "Manage Profile" as UC_Profile

  usecase "Browse Movies & Shows" as UC_Browse
  usecase "View Movie Details" as UC_MovieDetail
  usecase "View Trailers" as UC_Trailer
  usecase "Search Movies" as UC_Search

  usecase "Book Ticket" as UC_Book
  usecase "Select Cinema/Date/Time" as UC_SelectShow
  usecase "Select Seats" as UC_SelectSeats
  usecase "Reserve Seats" as UC_ReserveSeats
  usecase "Preview Dynamic Price" as UC_PricePreview
  usecase "Apply Coupon" as UC_ApplyCoupon
  usecase "Add Food/Combos" as UC_Food
  usecase "Make Payment" as UC_Payment
  usecase "Download Ticket" as UC_DownloadTicket

  usecase "View Booking History" as UC_BookingHistory
  usecase "Cancel Booking" as UC_CancelBooking
  usecase "Process Refund" as UC_Refund

  usecase "Group Booking" as UC_GroupBooking
  usecase "Invite Participants" as UC_GroupInvite
  usecase "Assign Seats (Bulk)" as UC_GroupAssign
  usecase "Split/Complete Group Payment" as UC_GroupPay

  usecase "Manage Wallet\n(Top-up / Pay)" as UC_Wallet
  usecase "Use Loyalty Rewards" as UC_Loyalty
  usecase "Manage Subscription" as UC_Subscription
  usecase "Use Referral Wallet" as UC_Referral
  usecase "View Notifications" as UC_Notifications
  usecase "Submit Private Screening Request" as UC_PrivateScreening

  usecase "Manage Shows & Schedule" as UC_VendorShows
  usecase "Manage Halls & Seat Layout" as UC_VendorSeats
  usecase "Manage Pricing Rules" as UC_VendorPricing
  usecase "Manage Food Items/Combos" as UC_VendorFood
  usecase "Validate Ticket Scan" as UC_Validate
  usecase "Monitor Ticket Validation" as UC_ValidateMonitor
  usecase "Manage Offers/Promo Codes/Campaigns" as UC_VendorPromo
  usecase "Manage Vendor Wallet & Withdrawals" as UC_VendorWallet
  usecase "View Vendor Analytics" as UC_VendorAnalytics
  usecase "Manage Vendor Staff Accounts" as UC_VendorStaff
  usecase "Manage Private Screening Requests" as UC_VendorPSR
  usecase "Manage Bulk Ticket Batches" as UC_VendorBulk
  usecase "Manage Vendor Cancellation Policy" as UC_VendorCancelPolicy

  usecase "Manage Movies/People/Credits" as UC_AdminCatalog
  usecase "Manage Banners, Slides, Collaborators" as UC_AdminContent
  usecase "Manage Users & Vendors" as UC_AdminActors
  usecase "Manage Bookings/Refunds/Dropoff Analytics" as UC_AdminBookings
  usecase "Manage Coupons & Global Pricing Rules" as UC_AdminPricing
  usecase "Manage Loyalty, Rewards, Promotions" as UC_AdminLoyalty
  usecase "Manage Subscription Plans" as UC_AdminSubs
  usecase "Manage Referral Controls" as UC_AdminReferral
  usecase "Approve/Reject Vendor Withdrawals" as UC_AdminWithdrawals
}

Guest --> UC_Browse
Guest --> UC_Search
Guest --> UC_MovieDetail
Guest --> UC_Trailer
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_ResetPass

Customer --> UC_Login
Customer --> UC_Profile
Customer --> UC_Book
Customer --> UC_DownloadTicket
Customer --> UC_BookingHistory
Customer --> UC_CancelBooking
Customer --> UC_GroupBooking
Customer --> UC_Wallet
Customer --> UC_Loyalty
Customer --> UC_Subscription
Customer --> UC_Referral
Customer --> UC_Notifications
Customer --> UC_PrivateScreening

Vendor --> UC_Login
Vendor --> UC_Profile
Vendor --> UC_VendorShows
Vendor --> UC_VendorSeats
Vendor --> UC_VendorPricing
Vendor --> UC_VendorFood
Vendor --> UC_Validate
Vendor --> UC_ValidateMonitor
Vendor --> UC_VendorPromo
Vendor --> UC_VendorWallet
Vendor --> UC_VendorAnalytics
Vendor --> UC_VendorStaff
Vendor --> UC_VendorPSR
Vendor --> UC_VendorBulk
Vendor --> UC_VendorCancelPolicy
Vendor --> UC_CancelBooking
Vendor --> UC_Refund

Admin --> UC_Login
Admin --> UC_Profile
Admin --> UC_AdminCatalog
Admin --> UC_AdminContent
Admin --> UC_AdminActors
Admin --> UC_AdminBookings
Admin --> UC_AdminPricing
Admin --> UC_AdminLoyalty
Admin --> UC_AdminSubs
Admin --> UC_AdminReferral
Admin --> UC_AdminWithdrawals
Admin --> UC_Refund

UC_MovieDetail .> UC_Trailer : <<include>>
UC_Book .> UC_SelectShow : <<include>>
UC_Book .> UC_SelectSeats : <<include>>
UC_Book .> UC_ReserveSeats : <<include>>
UC_Book .> UC_PricePreview : <<include>>
UC_Book .> UC_Payment : <<include>>
UC_ApplyCoupon .> UC_Book : <<extend>>
UC_Food .> UC_Book : <<extend>>
UC_Loyalty .> UC_Book : <<extend>>
UC_Subscription .> UC_Book : <<extend>>
UC_Referral .> UC_Book : <<extend>>
UC_DownloadTicket .> UC_Book : <<extend>>

UC_CancelBooking .> UC_Refund : <<include>>
UC_GroupBooking .> UC_GroupInvite : <<include>>
UC_GroupBooking .> UC_GroupAssign : <<include>>
UC_GroupBooking .> UC_GroupPay : <<include>>
UC_ValidateMonitor .> UC_Validate : <<include>>

UC_Payment --> PG
UC_Wallet --> PG
UC_Refund --> PG
UC_Notifications --> NS
UC_VendorPromo --> NS
UC_AdminBookings --> NS

@enduml

# Copy this file to .env.local (project root) and fill in values
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@example.com
# Optional: to use console backend for local dev set:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True

# eSewa ePay (TEST defaults)
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_FORM_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_CHECK_URL=https://rc.esewa.com.np/api/epay/transaction/status/
ESEWA_PENDING_TTL_SECONDS=1800

# Frontend app base used for payment callback URLs
FRONTEND_BASE_URL=http://localhost:5173

# Startup migration guard
DJANGO_AUTO_MIGRATE_ON_STARTUP=true
DJANGO_ENFORCE_SCHEMA_ON_STARTUP=true
DJANGO_SKIP_STARTUP_MIGRATIONS=false
DJANGO_VALIDATE_STARTUP_ENV=true
DJANGO_VALIDATE_STARTUP_DB_COLUMNS=true
DJANGO_SKIP_STARTUP_VALIDATIONS=false
# Optional custom lock file path for startup migration serialization
# DJANGO_STARTUP_MIGRATION_LOCK_FILE=

# Ticket validation API rate limits (requests per minute)
TICKET_VALIDATION_SCAN_RATE_LIMIT_STAFF_PER_MINUTE=60
TICKET_VALIDATION_SCAN_RATE_LIMIT_IP_PER_MINUTE=120
TICKET_VALIDATION_MONITOR_RATE_LIMIT_STAFF_PER_MINUTE=120
TICKET_VALIDATION_MONITOR_RATE_LIMIT_IP_PER_MINUTE=240
